{
    "name": "@ianlucas/cs2-lib-inspect",
    "description": "An extension for cs2-lib to create Counter-Strike 2 inspect links",
    "license": "MIT",
    "author": "Ian Lucas",
    "homepage": "https://github.com/ianlucas/cs2-lib-inspect#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ianlucas/cs2-lib-inspect.git"
    },
    "bugs": {
        "url": "https://github.com/ianlucas/cs2-lib-inspect/issues"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "docs": "typedoc --out docs src/index.ts",
        "format": "prettier . --write",
        "generate:protobufs": "npx protoc --experimental_allow_proto3_optional --ts_out ./src/Protobufs --proto_path src/Protobufs src/Protobufs/cstrike15_gcmessages.proto",
        "prepack": "([ -d dist ] && rm -rf dist); tsc",
        "test": "vitest --run --testTimeout 120000",
        "typecheck": "tsc --noEmit",
        "upgrade": "npx npm-check-updates@latest --target minor -u"
    },
    "dependencies": {
        "@protobuf-ts/runtime": "^2.11.1",
        "buffer": "^6.0.3",
        "crc-32": "^1.2.2",
        "vitest": "^4.1.4"
    },
    "peerDependencies": {
        "@ianlucas/cs2-lib": "^7.0.0"
    },
    "devDependencies": {
        "@protobuf-ts/plugin": "^2.11.1",
        "@total-typescript/tsconfig": "^1.0.4",
        "prettier": "^3.8.3",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=20"
    }
}
